# =====================================================================
# Tanque (torpasgas) environment. Copy to .env and fill in. NEVER commit .env.
# Generate secrets with:  openssl rand -base64 32   (and  openssl rand -hex 32)
# Legend: [SECRET] never commit/share  [PUBLIC] shipped to browser  [CONFIG] non-sensitive
# =====================================================================

# ---- Postgres (the db service) ----
POSTGRES_USER=torpasgas                           # [CONFIG]
POSTGRES_PASSWORD=change-me-strong-random         # [SECRET] openssl rand -base64 24
POSTGRES_DB=torpasgas                             # [CONFIG]

# ---- App DB connection (app + migrate). Host "db" = the compose service. ----
# Password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://torpasgas:change-me-strong-random@db:5432/torpasgas?sslmode=disable   # [SECRET]

# ---- Better Auth ----
BETTER_AUTH_SECRET=change-me-32-byte-random       # [SECRET] openssl rand -base64 32
BETTER_AUTH_URL=https://gas.torpasweb.com         # [CONFIG] public canonical origin

# ---- Public app URL (INLINED into the client bundle at BUILD time) ----
NEXT_PUBLIC_APP_URL=https://gas.torpasweb.com     # [PUBLIC]

# ---- Walleta (Saldo) integration — push each fill-up as an expense ----
# WALLETA_URL is the Saldo origin; the token is Saldo's INGEST_WEBHOOK_TOKEN.
# Leave both blank to disable (the "Add to Walleta" toggle disappears).
WALLETA_URL=https://saldo.torpasweb.com           # [CONFIG]
WALLETA_INGEST_TOKEN=                             # [SECRET] same value as Saldo's INGEST_WEBHOOK_TOKEN

# ---- Host port the app publishes (Caddy proxies to this) ----
APP_PORT=3000                                     # [CONFIG]
